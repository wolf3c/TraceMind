{
  "name": "tracemind-instrumentation",
  "guidanceVersion": "2026.05.09.1",
  "platforms": [
    "web",
    "ios",
    "android",
    "react_native",
    "mcp_node",
    "mcp_python",
    "agent_skill",
    "server_node",
    "server_python",
    "server_http"
  ],
  "resources": {
    "skill": "/agents/tracemind/SKILL.md",
    "agentSnippet": "/agents/tracemind/AGENTS_SNIPPET.md",
    "manifest": "/agents/tracemind/manifest.json"
  },
  "mcp": {
    "serverNamePattern": "tracemind-<project-code>",
    "tools": [
      "tracemind.project_info",
      "tracemind.agent_guidance",
      "tracemind.capture_setup",
      "tracemind.search_event_names",
      "tracemind.suggest_instrumentation",
      "tracemind.validate_event_payload",
      "tracemind.validate_instrumentation_diff",
      "tracemind.privacy_check"
    ]
  },
  "updatePolicy": "Check tracemind.agent_guidance before changing TraceMind instrumentation. In multi-project setups, use tracemind.project_info or MCP tool metadata to confirm the project before adding events. Ask the user before updating local skill or instruction files."
}
