{
  "name": "TraceMind",
  "version": "2026.7.16-1",
  "private": true,
  "scripts": {
    "start": "meteor run",
    "pretest": "npm run check:release-metadata && npm run test:sdk-release && npm run test:deploy-gates",
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "prepare:sdk-release-ref": "node scripts/prepare-sdk-release-ref.js",
    "check:deploy-git-publication": "node scripts/check-deploy-git-publication.js",
    "check:sdk-registry-publication": "node scripts/check-sdk-registry-publication.js",
    "check:release-metadata": "node scripts/check-release-metadata.js",
    "build:capture-static": "node scripts/capture-static-assets.js",
    "check:capture-static-publication": "node scripts/check-capture-static-publication.js",
    "update:sdk-manifest": "node scripts/check-sdk-release-manifest.js --write",
    "test:sdk-release": "node scripts/check-sdk-release-manifest.js --check",
    "test:deploy-gates": "node --test scripts/deploy-git-publication.test.js scripts/sdk-registry-publication.test.js scripts/release-metadata.test.js scripts/capture-static-assets.test.js scripts/cloudflare-capture-workflow.test.js",
    "test:sdk:android": "sh sdk/android/test.sh",
    "test:sdk:ios": "CLANG_MODULE_CACHE_PATH=.swiftpm-cache/clang swift test --disable-sandbox --package-path sdk/ios",
    "test:sdk:mcp-node": "npm test --prefix sdk/mcp-node",
    "test:sdk:mcp-python": "PYTHONPATH=sdk/mcp-python python3 -m unittest discover -s sdk/mcp-python/tests",
    "test:sdk:browser-extension": "npm test --prefix sdk/browser-extension",
    "test:sdk:mini-program": "npm test --prefix sdk/mini-program",
    "test:sdk:react-native": "npm test --prefix sdk/react-native",
    "test:sdk:server-node": "npm test --prefix sdk/server-node",
    "test:sdk:server-python": "PYTHONPATH=sdk/server-python python3 -m unittest discover -s sdk/server-python/tests",
    "test-app": "TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
    "visualize": "meteor --production --extra-packages bundle-visualizer",
    "deploy": "meteor deploy tracemind.sandbox.galaxycloud.app --settings .deploy/settings.json",
    "deploy:logs": "meteor logs tracemind.sandbox.galaxycloud.app",
    "deploy:selfhost:setup": "mup setup --config .deploy/mup.js",
    "deploy:selfhost": "mup deploy --config .deploy/mup.js --settings .deploy/settings.json",
    "deploy:selfhost:logs": "mup logs --config .deploy/mup.js -f"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.5",
    "@swc/helpers": "^0.5.17",
    "@tracemind/server-node": "2026.5.18-1",
    "meteor-node-stubs": "^1.2.12",
    "terser": "^5.46.2"
  },
  "devDependencies": {
    "@meteorjs/rspack": "^2.0.1",
    "@rsdoctor/rspack-plugin": "^1.5.7",
    "@rspack/cli": "1.7.1",
    "@rspack/core": "1.7.1",
    "postcss-load-config": "^5.1.0",
    "svelte": "^5.38.2",
    "svelte-check": "^4.3.1",
    "svelte-loader": "^3.2.4",
    "svelte-preprocess": "^6.0.3"
  },
  "meteor": {
    "mainModule": {
      "client": "client/main.js",
      "server": "server/main.js"
    },
    "testModule": "tests/main.js",
    "modern": true
  }
}
