{
  "name": "TraceMind",
  "private": true,
  "scripts": {
    "start": "meteor run",
    "test": "meteor test --once --driver-package meteortesting:mocha",
    "test:sdk:android": "sh sdk/android/test.sh",
    "test:sdk:ios": "CLANG_MODULE_CACHE_PATH=.swiftpm-cache/clang swift test --disable-sandbox --package-path sdk/ios",
    "test:sdk:react-native": "npm test --prefix sdk/react-native",
    "test-app": "TEST_WATCH=1 meteor test --full-app --driver-package meteortesting:mocha",
    "visualize": "meteor --production --extra-packages bundle-visualizer",
    "deploy": "meteor deploy tracemind.sandbox.galaxycloud.app --settings .deploy/settings.json",
    "deploy:logs": "meteor logs tracemind.sandbox.galaxycloud.app",
    "deploy:selfhost:setup": "mup setup --config .deploy/mup.js",
    "deploy:selfhost": "mup deploy --config .deploy/mup.js --settings .deploy/settings.json",
    "deploy:selfhost:logs": "mup logs --config .deploy/mup.js -f"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.5",
    "@swc/helpers": "^0.5.17",
    "meteor-node-stubs": "^1.2.12"
  },
  "devDependencies": {
    "@meteorjs/rspack": "^2.0.1",
    "@rsdoctor/rspack-plugin": "^1.5.7",
    "@rspack/cli": "1.7.1",
    "@rspack/core": "1.7.1",
    "postcss-load-config": "^5.1.0",
    "svelte": "^5.38.2",
    "svelte-check": "^4.3.1",
    "svelte-loader": "^3.2.4",
    "svelte-preprocess": "^6.0.3"
  },
  "meteor": {
    "mainModule": {
      "client": "client/main.js",
      "server": "server/main.js"
    },
    "testModule": "tests/main.js",
    "modern": true
  }
}
